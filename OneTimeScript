from pinecone import Pinecone, ServerlessSpec
import os

pc = Pinecone(api_key=os.getenv("PINECONE_API_KEY"))

index_name = "rag-portfolio"

# ⚠️ Delete old index first (optional but recommended)
if index_name in [i["name"] for i in pc.list_indexes()]:
    pc.delete_index(index_name)

# Create new index
pc.create_index(
    name=index_name,
    dimension=384,  # IMPORTANT (matches text-embedding-3-small)
    metric="cosine",
    spec=ServerlessSpec(
        cloud="aws",
        region="us-east-1"
    )
)

print("Index created!")